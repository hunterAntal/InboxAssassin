MODEL_BACKEND=gemini
GEMINI_API_KEY=your-api-key-here

# Ollama (if using local backend)
# MODEL_BACKEND=local
# LOCAL_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# Inbox behaviour
MAX_EMAILS=50
MAX_BATCHES=0
PRE_FILTER=true
SEND_DIGEST=true
ARCHIVE_PRIORITY=2

# Digest schedule (24h, local time)
DIGEST_MORNING_HOUR=8
DIGEST_EVENING_HOUR=20
TZ=America/Toronto
